# Docker Environment Configuration
# This file contains default values for Docker deployment

# MinIO Configuration
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123

# S3 Configuration for Go Backend
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_USE_SSL=false

# gRPC Configuration
GRPC_BACKEND_HOST=go-backend
GRPC_BACKEND_PORT=8780

# Web Interface Configuration  
VITE_GRPC_SERVER_URL=http://localhost:8080
VITE_FILE_SERVER_URL=http://localhost:9000